# ── main music screen ─────────────────────────────────────────────────────────

class MusicApp(Screen):
    BINDINGS = [
        Binding("/",         "focus_search", "/ Search"),
        Binding("enter",     "play",         "", show=False),
        Binding("space",     "pause",        "Spc Pause"),
        Binding("n",         "nxt",          "N Next"),
        Binding("p",         "prv",          "P Prev"),
        Binding("comma",     "seek_back",    ", -5s"),
        Binding("full_stop", "seek_fwd",     ". +5s"),
        Binding("a",         "add_q",        "A Queue"),
        Binding("d",         "download",     "D DL"),
        Binding("c",         "clear_q",      "C Clear"),
        Binding("l",         "library",      "L Liked"),
        Binding("+",         "vol_up",       "+ Vol+"),
        Binding("-",         "vol_dn",       "- Vol-"),
        Binding("q",         "back",         "Q Back"),
        Binding("escape",    "back",         "", show=False),
    ]

    def __init__(self, mode="online", local_folder=None):
        super().__init__()
        self.mode = mode
        self.local_folder = local_folder
        self._results = []
        self._queue   = []
        self._qidx    = -1
        self._now     = None
        self._filter  = "songs"
        self._FILTERS = ["songs", "videos"]

    def compose(self) -> ComposeResult:
        # topbar
        with Horizontal(id="topbar"):
            yield Label("  MUSIC", id="logo")
            if self.mode == "online":
                yield Input(placeholder="  search YouTube Music...", id="search-input")
                yield Label("songs [Tab]", id="filter-lbl")
            else:
                yield Label(
                    f"  Local: {self.local_folder}",
                    id="search-input")
                yield Label("", id="filter-lbl")
        # body
        with Horizontal(id="body"):
            with Vertical(id="left"):
                yield Label("  RESULTS", classes="hdr", id="res-hdr")
                yield ListView(id="results")
            with Vertical(id="right"):
                yield Static("", id="nowplaying")
                yield Label("  QUEUE", classes="hdr", id="q-hdr")
                yield ListView(id="queue")
        # player
        with Vertical(id="player"):
            with Horizontal(id="player-top"):
                yield Static("  nothing playing", id="player-info", markup=False)
                yield Static("<<  >  >>", id="player-ctrl", markup=False)
            yield Static("  [░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░]  --:-- / --:--  vol 80%",
                         id="player-prog", markup=False)
        # hints
        yield Static(
            "  [/] Search  [Enter] Play  [Spc] Pause  [N/P] Skip  [,/.] Seek"
            "  [A] Queue  [D] Download  [L] Liked  [+/-] Vol  [Q] Back",
            id="hints", markup=False)

    def on_mount(self):
        self._refresh_np()
        self._refresh_pb()
        if self.mode == "local":
            self._load_local()
        else:
            try:
                self.query_one("#search-input", Input).focus()
            except Exception:
                pass
        self.set_interval(1, self._tick)

    # ── auto-advance ──

    def _tick(self):
        if not MPV.alive() and self._now and not MPV.paused:
            if self._qidx < len(self._queue) - 1:
                self._qidx += 1
                self._play(self._queue[self._qidx])
        self._refresh_pb()

    # ── now playing display ──

    def _refresh_np(self):
        w = self.query_one("#nowplaying", Static)
        t = self._now
        if t is None:
            w.update("  nothing playing\n\n  search and press Enter to play")
            return
        icon = "> playing" if MPV.alive() and not MPV.paused else "|| paused"
        lines = [
            "",
            f"  {t['title'][:50]}",
            f"  {t['artist'][:40]}",
            "",
            f"  {icon}   vol {MPV.volume}%",
        ]
        w.update("\n".join(lines))

    # ── progress bar ──

    def _refresh_pb(self):
        wp = self.query_one("#player-prog", Static)
        wi = self.query_one("#player-info", Static)
        wc = self.query_one("#player-ctrl", Static)
        if not self._now:
            wp.update("  [" + "░"*36 + "]  --:-- / --:--  vol " + str(MPV.volume) + "%")
            wi.update("  nothing playing")
            wc.update("<<  >  >>")
            return
        pos = MPV.pos(); dur = MPV.dur()
        bar = pbar(pos, dur, 36)
        icon = ">" if MPV.alive() and not MPV.paused else "||"
        t = self._now
        wi.update(f"  {t['title'][:40]}  —  {t['artist'][:25]}")
        wc.update(f"<<  {icon}  >>")
        wp.update(f"  [{bar}]  {fmt(pos)} / {fmt(dur)}  vol {MPV.volume}%")

    # ── list builders ──

    def _rebuild_results(self):
        lv = self.query_one("#results", ListView)
        lv.clear()
        self.query_one("#res-hdr", Label).update(
            f"  RESULTS ({len(self._results)})")
        for i, t in enumerate(self._results):
            playing = self._now and self._now["id"] == t["id"]
            pre = ">" if playing else " "
            row = f"  {pre} {i+1:>2}  {t['title'][:38]}  {t['artist'][:20]}  {t['duration'][:5]}"
            lv.append(ListItem(Label(row, markup=False)))

    def _rebuild_queue(self):
        lv = self.query_one("#queue", ListView)
        lv.clear()
        self.query_one("#q-hdr", Label).update(
            f"  QUEUE ({len(self._queue)})")
        for i, t in enumerate(self._queue):
            playing = i == self._qidx
            pre = ">" if playing else " "
            row = f"  {pre} {i+1:>2}  {t['title'][:28]}  {t['artist'][:18]}"
            lv.append(ListItem(Label(row, markup=False)))

    def _status(self, msg):
        self.query_one("#player-info", Static).update(f"  {msg}")

    # ── play ──

    def _play(self, track):
        self._now = track
        self._refresh_np()
        self._refresh_pb()
        self._rebuild_results()
        self._rebuild_queue()
        self._status(f"  loading: {track['title'][:40]}...")
        if track["source"] == "local":
            MPV.play(track["id"])
            self._status(f"  > {track['title'][:40]}")
            self._refresh_np()
        else:
            self._stream(track)

    @work(thread=True)
    def _stream(self, track):
        url = stream_url(track["id"])
        if not url:
            self.app.call_from_thread(self._status, f"  stream failed: {track['title'][:30]}")
            return
        MPV.play(url)
        self.app.call_from_thread(self._status, f"  > {track['title'][:40]} - {track['artist'][:25]}")
        self.app.call_from_thread(self._refresh_np)

    # ── actions ──

    def action_focus_search(self):
        if self.mode == "online":
            try: self.query_one("#search-input", Input).focus()
            except: pass

    def action_play(self):
        if self.mode == "online":
            try:
                si = self.query_one("#search-input", Input)
                if si.has_focus:
                    q = si.value.strip()
                    if q: self._do_search(q)
                    return
            except: pass
        lv  = self.query_one("#results", ListView)
        idx = lv.index
        if idx is None or idx >= len(self._results): return
        t = self._results[idx]
        self._queue.append(t)
        self._qidx = len(self._queue) - 1
        self._play(t)

    @work(thread=True)
    def _do_search(self, q):
        self.app.call_from_thread(self._status, f"  searching: {q[:30]}...")
        results = search_ytm(q, self._filter)
        if not results:
            self.app.call_from_thread(self._status, f"  no results for: {q[:30]}")
            return
        self._results = results
        self.app.call_from_thread(self._rebuild_results)
        self.app.call_from_thread(self._status, f"  {len(results)} results")
        self.app.call_from_thread(self.query_one("#results").focus)

    @work(thread=True)
    def _load_local(self):
        self.app.call_from_thread(self._status, "  scanning local files...")
        tracks = scan_local(self.local_folder)
        self._results = tracks
        self.app.call_from_thread(self._rebuild_results)
        self.app.call_from_thread(self._status, f"  {len(tracks)} local files")
        self.app.call_from_thread(self.query_one("#results").focus)

    def action_pause(self):
        if not self._now: return
        MPV.toggle_pause()
        self._refresh_np(); self._refresh_pb()

    def action_nxt(self):
        if self._qidx < len(self._queue) - 1:
            self._qidx += 1; self._play(self._queue[self._qidx])

    def action_prv(self):
        if self._qidx > 0:
            self._qidx -= 1; self._play(self._queue[self._qidx])

    def action_seek_back(self):
        if MPV.alive(): MPV.seek(-5); self._refresh_pb()

    def action_seek_fwd(self):
        if MPV.alive(): MPV.seek(5); self._refresh_pb()

    def action_add_q(self):
        lv  = self.query_one("#results", ListView)
        idx = lv.index
        if idx is None or idx >= len(self._results): return
        t = self._results[idx]
        self._queue.append(t); self._rebuild_queue()
        self._status(f"  queued: {t['title'][:30]}")

    @work(thread=True)
    def action_download(self):
        lv  = self.query_one("#results", ListView)
        idx = lv.index
        if idx is None or idx >= len(self._results): return
        t = self._results[idx]
        if t["source"] != "online":
            self.app.call_from_thread(self._status, "  already local"); return
        self.app.call_from_thread(self._status, f"  downloading {t['title'][:30]}...")
        ok, path = dl_track(t["id"], t["title"])
        self.app.call_from_thread(self._status,
            f"  saved to {path}" if ok else "  download failed")

    def action_clear_q(self):
        MPV.stop(); self._queue = []; self._qidx = -1; self._now = None
        self._rebuild_queue(); self._refresh_np(); self._refresh_pb()

    @work(thread=True)
    def action_library(self):
        if not AUTH.exists():
            self.app.call_from_thread(self._status, "  run: music --setup"); return
        self.app.call_from_thread(self._status, "  loading liked songs...")
        tracks = get_liked()
        if not tracks:
            self.app.call_from_thread(self._status, "  no liked songs found"); return
        self._results = tracks
        self.app.call_from_thread(self._rebuild_results)
        self.app.call_from_thread(self._status, f"  {len(tracks)} liked songs")
        self.app.call_from_thread(self.query_one("#results").focus)

    def action_vol_up(self):  MPV.set_vol(MPV.volume + 5); self._refresh_pb()
    def action_vol_dn(self):  MPV.set_vol(MPV.volume - 5); self._refresh_pb()

    def action_back(self):
        MPV.stop()
        self.app.pop_screen()

    # ── Tab cycles filter ──

    def on_key(self, event):
        if event.key == "tab" and self.mode == "online":
            try:
                si = self.query_one("#search-input", Input)
                if si.has_focus:
                    event.stop()
                    i = self._FILTERS.index(self._filter)
                    self._filter = self._FILTERS[(i+1) % len(self._FILTERS)]
                    self.query_one("#filter-lbl", Label).update(
                        f"{self._filter} [Tab]")
            except: pass

    @on(Input.Submitted, "#search-input")
    def on_search(self, e):
        q = e.value.strip()
        if q: self._do_search(q)

    @on(ListView.Selected, "#results")
    def on_res_sel(self, e): self.action_play()

    @on(ListView.Selected, "#queue")
    def on_q_sel(self, e):
        idx = e.list_view.index
        if idx is not None and idx < len(self._queue):
            self._qidx = idx; self._play(self._queue[idx])

# ── root app ──────────────────────────────────────────────────────────────────

class Root(App):
    CSS = APP_CSS

    def on_mount(self):
        self.push_screen(HomeScreen())


if __name__ == "__main__":
    try: Root().run()
    finally: MPV.stop()
