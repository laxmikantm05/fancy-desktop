class MusicApp:
    def __init__(self):
        self._res    = []
        self._q      = []
        self._qi     = -1
        self._now    = None
        self._view   = "search"
        self._status = "  press / to search"
        self._focus         = "results"   # "results" | "queue"
        self._prefetched_dur = 0.0
        self._repeat        = 0   # 0=off  1=one  2=all

        # ── top bar ───────────────────────────────────────────────────────────
        logo        = urwid.Text([("title", " YTMusic"), ("dim", "  │")])
        self._sedit = SearchEdit(on_submit=self._do_search)
        search_am   = urwid.AttrMap(self._sedit, "input", "input_focus")
        view_lbl    = urwid.Text(("dim", "songs "), align="right")

        topbar = urwid.Columns([
            ("fixed", 12, logo),
            search_am,
            ("fixed", 8, view_lbl),
        ], dividechars=1)

        top_div   = urwid.AttrMap(urwid.Divider("─"), "border")
        top_block = urwid.Pile([topbar, top_div])

        # ── column header ─────────────────────────────────────────────────────
        self._col_hdr = urwid.Text(("col_hdr",
            f"  {'#':>3}  {'title':<40}  {'artist':<22}  time"))

        # ── results list ──────────────────────────────────────────────────────
        self._res_walker  = urwid.SimpleFocusListWalker([])
        self._res_listbox = urwid.ListBox(self._res_walker)
        results_area      = urwid.Frame(self._res_listbox, header=self._col_hdr)

        # ── queue panel ───────────────────────────────────────────────────────
        self._q_hdr    = urwid.Text(("col_hdr", "  queue"))
        self._q_walker = urwid.SimpleFocusListWalker([])
        self._q_box    = urwid.ListBox(self._q_walker)
        queue_area     = urwid.Frame(self._q_box, header=self._q_hdr)

        # Thin vertical divider between results and queue
        q_div = urwid.AttrMap(urwid.SolidFill("│"), "border")

        # ── body: results | divider | queue ───────────────────────────────────
        body = urwid.Columns([
            results_area,
            ("fixed", 1,  q_div),
            ("fixed", 30, queue_area),
        ], dividechars=0)

        # ── player footer ─────────────────────────────────────────────────────
        player_div     = urwid.AttrMap(urwid.Divider("─"), "border")

        self._p_icon   = urwid.Text(("dim", "  ──"), align="left")
        self._p_repeat = urwid.Text(("dim", ""), align="right")
        self._p_title  = urwid.Text(("dim", "  nothing playing"))
        self._p_vol    = urwid.Text(("dim", "vol 80%"), align="right")

        self._p_time_l = urwid.Text(("dim", "00:00"))
        self._p_bar    = urwid.Text(("bar_empty", "─" * 40))
        self._p_time_r = urwid.Text(("dim", "00:00"), align="right")
        self._p_status = urwid.Text(("hint", ""))

        row1 = urwid.Columns([
            ("fixed", 5,  self._p_icon),
            self._p_title,
            ("fixed", 8,  self._p_repeat),
            ("fixed", 10, self._p_vol),
        ])
        row2 = urwid.Columns([
            ("fixed", 6, self._p_time_l),
            self._p_bar,
            ("fixed", 6, self._p_time_r),
        ])

        hint1 = urwid.Text(("hint",
            "  [/] search  [↵] play  [Space] pause  [n] next  [p] prev  [<] -5s  [>] +5s"))
        hint2 = urwid.Text(("hint",
            "  [a] queue   [x] remove  [d] download  [c] clear  [r] repeat  [+][-] vol  [q] quit"))

        footer = urwid.Pile([
            player_div,
            row1,
            row2,
            self._p_status,
            hint1,
            hint2,
        ])

        # ── root frame ────────────────────────────────────────────────────────
        self._frame = urwid.Frame(
            body   = body,
            header = top_block,
            footer = footer,
        )

        # 256-color screen for proper #ff0033 red
        screen = urwid.raw_display.Screen()
        screen.set_terminal_properties(colors=256)

        self._loop = urwid.MainLoop(
            self._frame,
            palette         = PALETTE,
            screen          = screen,
            unhandled_input = self._handle_key,
        )
        self._pipe = self._loop.watch_pipe(self._on_pipe)

    # ── pipe / refresh ────────────────────────────────────────────────────────
    def _signal(self):
        try: os.write(self._pipe, b"r")
        except: pass

    def _on_pipe(self, _data):
        self._rebuild_results()
        self._rebuild_queue()
        self._draw_player()

    # ── key handler ───────────────────────────────────────────────────────────
    def _handle_key(self, key):
        # Hand off to search box
        if key in ("/", "s"):
            self._frame.focus_position = "header"
            return

        # Tab: cycle focus between results and queue
        if key == "tab":
            if self._focus == "results":
                self._focus = "queue"
                try:
                    self._frame.focus_position = "body"
                    self._frame.body.focus_position = 2
                except Exception: pass
            else:
                self._focus = "results"
                try:
                    self._frame.focus_position = "body"
                    self._frame.body.focus_position = 0
                except Exception: pass
            return

        if key == "enter":
            # results: play selected
            if self._focus == "results":
                try:
                    idx = self._res_listbox.focus_position
                    self._play_at(idx)
                except Exception: pass
            # queue: jump to selected
            elif self._focus == "queue":
                try:
                    idx = self._q_box.focus_position
                    if 0 <= idx < len(self._q):
                        self._qi = idx
                        self._play(self._q[idx])
                except Exception: pass
            return

        k = key.lower() if isinstance(key, str) else key

        if   key == " ":  self._action_pause()
        elif k   == "n":  self._action_next()
        elif k   == "p":  self._action_prev()
        elif key == ",":                           # actual key ,  shown as <
            if MPV.alive(): MPV.seek(-5)
        elif key == ".":                           # actual key .  shown as >
            if MPV.alive(): MPV.seek(5)
        elif k   == "a":  self._action_addq()
        elif k   == "x":  self._action_removeq()
        elif k   == "d":  threading.Thread(target=self._action_dl,    daemon=True).start()
        elif k   == "l":  threading.Thread(target=self._action_liked, daemon=True).start()
        elif k   == "o":  threading.Thread(target=self._action_local, daemon=True).start()
        elif k   == "c":  self._action_clear()
        elif key in ("+", "="):                    # actual key =  shown as +
            MPV.set_vol(MPV.volume + 5);  self._draw_player()
        elif key == "-":
            MPV.set_vol(MPV.volume - 5);  self._draw_player()
        elif k   == "r":  self._action_repeat()
        elif k   == "q":  raise urwid.ExitMainLoop()

    # ── player draw ───────────────────────────────────────────────────────────
    def _draw_player(self):
        t   = self._now
        pos = MPV.pos()
        dur = MPV.dur()

        if t:
            is_playing = MPV.alive() and not MPV.paused
            if is_playing:
                self._p_icon.set_text(("red_bold", "  ▶ "))
            else:
                self._p_icon.set_text(("paused",   "  || "))
            self._p_title.set_text([
                ("bold", f" {trunc(t['title'], 48)}"),
                ("dim",  f"  —  {trunc(t['artist'], 24)}"),
            ])
        else:
            self._p_icon.set_text(("dim", "  ── "))
            self._p_title.set_text(("dim", "  nothing playing"))

        self._p_vol.set_text(("dim", f"vol {MPV.volume}%"))
        _rep_labels = {0: ("dim", "       "), 1: ("red_bold", " ↺ one "), 2: ("red_bold", " ↺ all ")}
        self._p_repeat.set_text(_rep_labels[self._repeat])
        self._p_time_l.set_text(("dim", fmt(pos)))
        self._p_time_r.set_text(("dim", fmt(dur)))

        if dur > 0:
            W      = 40
            filled = int(min(pos / dur, 1.0) * W)
            empty  = W - filled
            parts  = []
            if filled: parts.append(("bar_fill",  "━" * filled))
            if empty:  parts.append(("bar_empty", "─" * empty))
            self._p_bar.set_text(parts)
        else:
            self._p_bar.set_text(("bar_empty", "─" * 40))

        self._p_status.set_text(("hint", f"  {self._status}"))

    # ── results rebuild ───────────────────────────────────────────────────────
    def _rebuild_results(self):
        n        = len(self._res)
        view_lbl = {"search": f"results ({n})",
                    "liked":  f"liked ({n})",
                    "local":  f"files ({n})"}.get(self._view, "")
        self._col_hdr.set_text([
            ("col_hdr", f"  {'#':>3}  {'title':<40}  {'artist':<22}  time"),
            ("dim",     f"   [{view_lbl}]"),
        ])

        rows = []
        for i, t in enumerate(self._res):
            playing = self._now and self._now["id"] == t["id"]
            dur     = t["duration"][:5]
            title   = trunc(t["title"],  40)
            artist  = trunc(t["artist"], 22)
            if playing:
                markup_n = [
                    ("red_bold", f"  ▶  {i+1:>3}  "),
                    ("playing",  f"{title:<40}"),
                    ("dim",      f"  {artist:<22}  "),
                    ("dim",      dur),
                ]
                markup_f = [
                    ("red_bold", f" »▶  {i+1:>3}  "),
                    ("playing",  f"{title:<40}"),
                    ("dim",      f"  {artist:<22}  "),
                    ("dim",      dur),
                ]
            else:
                markup_n = [
                    ("dim",   f"     {i+1:>3}  "),
                    ("white", f"{title:<40}"),
                    ("dim",   f"  {artist:<22}  "),
                    ("dim",   dur),
                ]
                markup_f = [
                    ("red",   f"  »  {i+1:>3}  "),
                    ("white", f"{title:<40}"),
                    ("dim",   f"  {artist:<22}  "),
                    ("dim",   dur),
                ]
            row = SelectableRow(markup_n, markup_focused=markup_f, focus_map="focus")
            rows.append(row)

        # Preserve focus position if possible
        try:    old_focus = self._res_listbox.focus_position
        except: old_focus = 0

        self._res_walker[:] = rows

        if rows:
            new_focus = min(old_focus, len(rows) - 1)
            try: self._res_listbox.set_focus(new_focus)
            except Exception: pass

    # ── queue rebuild ─────────────────────────────────────────────────────────
    def _rebuild_queue(self):
        n = len(self._q)
        self._q_hdr.set_text([
            ("col_hdr", "  queue"),
            ("dim",     f"  ({n})"),
        ])

        rows = []
        for i, t in enumerate(self._q):
            is_cur  = (i == self._qi)
            dur     = t["duration"][:5]
            title   = trunc(t["title"], 19)
            if is_cur:
                markup_n = [
                    ("red_bold", " » "),
                    ("playing",  f"{title:<19}"),
                    ("dim",      f"  {dur:<5}"),
                ]
                markup_f = [
                    ("red_bold", " » "),
                    ("playing",  f"{title:<19}"),
                    ("dim",      f"  {dur:<5}"),
                ]
            else:
                markup_n = [
                    ("dim",   "   "),
                    ("white", f"{title:<19}"),
                    ("dim",   f"  {dur:<5}"),
                ]
                markup_f = [
                    ("red",   " » "),
                    ("white", f"{title:<19}"),
                    ("dim",   f"  {dur:<5}"),
                ]
            row = SelectableRow(markup_n, markup_focused=markup_f, focus_map="focus_queue")
            rows.append(row)

        try:    old_focus = self._q_box.focus_position
        except: old_focus = 0

        self._q_walker[:] = rows

        if rows:
            new_focus = min(old_focus, len(rows) - 1)
            try: self._q_box.set_focus(new_focus)
            except Exception: pass

    # ── playback ──────────────────────────────────────────────────────────────
    def _play_at(self, idx):
        if idx < 0 or idx >= len(self._res): return
        t = self._res[idx]
        # Add to queue if not already there
        if t not in self._q:
            self._q.append(t)
        self._qi = self._q.index(t)
        self._play(t)

    def _play(self, track):
        self._now    = track
        self._status = f"loading: {trunc(track['title'], 40)}..."
        self._rebuild_results()
        self._rebuild_queue()
        self._draw_player()
        if track["source"] == "local":
            MPV.play(track["id"])
            self._status = trunc(track["title"], 50)
            self._draw_player()
        else:
            threading.Thread(target=self._stream_thread, args=(track,), daemon=True).start()

    def _stream_thread(self, track):
        url, dur = stream_url(track["id"])
        if not url:
            self._status = "stream failed — try: pip install -U yt-dlp --break-system-packages"
            self._signal(); return
        self._prefetched_dur = dur
        MPV.play(url)
        self._status = trunc(track["title"], 50)
        self._signal()

    # ── tick ──────────────────────────────────────────────────────────────────
    def _tick(self, loop, _data):
        if not MPV.alive() and self._now and not MPV.paused:
            if self._repeat == 1:                        # repeat one
                self._play(self._q[self._qi])
            elif self._qi < len(self._q) - 1:           # normal / repeat-all advance
                self._qi += 1; self._play(self._q[self._qi])
            elif self._repeat == 2 and self._q:          # repeat all — wrap to start
                self._qi = 0; self._play(self._q[0])
        self._draw_player()
        self._loop.set_alarm_in(1, self._tick)

    # ── actions ───────────────────────────────────────────────────────────────
    def _do_search(self, q):
        if not q: return
        self._status = f"searching: {q[:30]}..."
        self._draw_player()
        # Shift focus back to results after submitting
        try:
            self._frame.focus_position = "body"
            self._frame.body.focus_position = 0
            self._focus = "results"
        except Exception: pass
        threading.Thread(target=self._search_thread, args=(q,), daemon=True).start()

    def _search_thread(self, q):
        results      = search_ytm(q)
        self._res    = results
        self._view   = "search"
        self._status = f"{len(results)} results" if results else f"no results: {q[:30]}"
        self._signal()

    def _action_repeat(self):
        self._repeat = (self._repeat + 1) % 3
        labels = {0: "repeat off", 1: "repeat one", 2: "repeat all"}
        self._status = labels[self._repeat]
        self._draw_player()

    def _action_pause(self):
        if not self._now: return
        MPV.toggle_pause(); self._draw_player()

    def _action_next(self):
        if self._qi < len(self._q) - 1:
            self._qi += 1; self._play(self._q[self._qi])

    def _action_prev(self):
        if self._qi > 0:
            self._qi -= 1; self._play(self._q[self._qi])

    def _action_addq(self):
        try:
            idx = self._res_listbox.focus_position
            if idx < len(self._res):
                t = self._res[idx]
                if t not in self._q:
                    self._q.append(t)
                    self._status = f"queued: {trunc(t['title'], 30)}"
                else:
                    self._status = "already in queue"
                self._rebuild_queue()
                self._draw_player()
        except Exception: pass

    def _action_removeq(self):
        """Remove focused item from queue (x key)."""
        try:
            idx = self._q_box.focus_position
            if 0 <= idx < len(self._q):
                removed = self._q.pop(idx)
                # Adjust current index
                if self._qi >= idx and self._qi > 0:
                    self._qi -= 1
                self._status = f"removed: {trunc(removed['title'], 30)}"
                self._rebuild_queue()
                self._draw_player()
        except Exception: pass

    def _action_dl(self):
        try:
            idx = self._res_listbox.focus_position
            if idx >= len(self._res): return
            t = self._res[idx]
            if t["source"] != "online":
                self._status = "already local"; self._signal(); return
            self._status = f"downloading {trunc(t['title'], 30)}..."; self._signal()
            ok, path     = dl_track(t["id"], t["title"])
            self._status = f"saved to {path}" if ok else "download failed"
            self._signal()
        except Exception: pass

    def _action_liked(self):
        if not AUTH.exists():
            self._status = "run: music --setup"; self._signal(); return
        self._status = "loading liked songs..."; self._signal()
        tracks       = get_liked()
        self._res    = tracks; self._view = "liked"
        self._status = f"{len(tracks)} liked songs" if tracks else "no liked songs found"
        self._signal()

    def _action_local(self):
        folder = str(pathlib.Path.home() / "Music")
        if not os.path.isdir(folder):
            self._status = "~/Music not found"; self._signal(); return
        self._status = "scanning local files..."; self._signal()
        tracks       = scan_local(folder)
        self._res    = tracks; self._view = "local"
        self._status = f"{len(tracks)} local files"
        self._signal()

    def _action_clear(self):
        MPV.stop(); self._q = []; self._qi = -1; self._now = None
        self._rebuild_results(); self._rebuild_queue(); self._draw_player()

    # ── run ───────────────────────────────────────────────────────────────────
    def run(self):
        self._rebuild_results()
        self._rebuild_queue()
        self._draw_player()
        self._loop.set_alarm_in(1, self._tick)
        try:
            self._loop.run()
        except KeyboardInterrupt:
            pass


if __name__ == "__main__":
    try:
        MusicApp().run()
    except KeyboardInterrupt:
        pass
    finally:
        MPV.cleanup()
