# ─── MPV backend ──────────────────────────────────────────────────────────────
class Mpv:
    def __init__(self):
        self._proc = None; self._lock = threading.Lock()
        self.paused = False; self.volume = 80
        self._pos = 0.0; self._dur = 0.0; self._run = False

    def _rpc(self, cmd, reply=False):
        try:
            s = socket.socket(socket.AF_UNIX, socket.SOCK_STREAM)
            s.settimeout(0.4); s.connect(MPV_SOCK)
            s.sendall((json.dumps(cmd) + "\n").encode())
            if reply:
                d = json.loads(s.recv(4096).decode()); s.close()
                return d.get("data")
            s.close()
        except: return None

    def _poll(self):
        while self._run:
            if self.alive():
                v = self._rpc({"command": ["get_property", "time-pos"]}, reply=True)
                if v is not None: self._pos = float(v)
                v = self._rpc({"command": ["get_property", "duration"]}, reply=True)
                if v is not None: self._dur = float(v)
            time.sleep(0.5)

    def play(self, url):
        self.stop(); time.sleep(0.15)
        with self._lock:
            self._proc = subprocess.Popen(
                ["mpv", "--no-video", "--really-quiet", "--no-ytdl",
                 f"--volume={self.volume}", f"--input-ipc-server={MPV_SOCK}", url],
                stdout=subprocess.DEVNULL, stderr=subprocess.DEVNULL)
            self.paused = False; self._pos = 0.0; self._dur = 0.0
        if not self._run:
            self._run = True
            threading.Thread(target=self._poll, daemon=True).start()

    def stop(self):
        with self._lock:
            if self._proc:
                try: self._proc.terminate(); self._proc.wait(timeout=2)
                except:
                    try: self._proc.kill()
                    except: pass
                self._proc = None; self.paused = False
        self._pos = 0.0; self._dur = 0.0

    def toggle_pause(self): self._rpc({"command": ["cycle", "pause"]}); self.paused = not self.paused
    def seek(self, s):      self._rpc({"command": ["seek", s, "relative"]})
    def set_vol(self, v):
        self.volume = max(0, min(130, v))
        self._rpc({"command": ["set_property", "volume", self.volume]})
    def pos(self):  return self._pos
    def dur(self):  return self._dur
    def alive(self):
        with self._lock: return self._proc is not None and self._proc.poll() is None
    def cleanup(self): self._run = False; self.stop()

MPV = Mpv()


# ─── helpers ──────────────────────────────────────────────────────────────────
def fmt(s):
    s = int(max(0, s)); return f"{s//60:02d}:{s%60:02d}"

def trunc(s, n):
    s = str(s); return s if len(s) <= n else s[:n-1] + "…"

def stream_url(vid):
    """Pre-fetch direct audio CDN URL via yt-dlp using android client to avoid 429."""
    try:
        r = subprocess.run(
            ["yt-dlp",
             "--extractor-args", "youtube:player_client=android",
             "-f", "bestaudio/best",
             "--no-playlist", "--quiet", "--no-warnings",
             "--print", "url",
             "--print", "duration",
             f"https://www.youtube.com/watch?v={vid}"],
            capture_output=True, text=True, timeout=30)
        lines = [l.strip() for l in r.stdout.splitlines() if l.strip()]
        url = next((l for l in lines if l.startswith("http")), None)
        dur = 0.0
        for l in lines:
            try:
                v = float(l)
                if 0 < v < 86400:
                    dur = v; break
            except: pass
        return url, dur
    except Exception:
        return None, 0.0

def dl_track(vid, title):
    d    = str(pathlib.Path.home() / "Music" / "ytmusic"); os.makedirs(d, exist_ok=True)
    safe = "".join(c for c in title if c.isalnum() or c in " -_")[:80]
    url  = f"https://www.youtube.com/watch?v={vid}"
    try:
        r = subprocess.run(
            ["yt-dlp",
             "--extractor-args", "youtube:player_client=android",
             "-f", "bestaudio/best",
             "-x", "--audio-format", "mp3", "--audio-quality", "0",
             "--no-playlist",
             "-o", f"{d}/{safe}.%(ext)s",
             url],
            capture_output=True, text=True, timeout=180)
        if r.returncode == 0:
            return True, d
        err = (r.stderr or r.stdout or "unknown error").strip().splitlines()
        return False, next((l for l in err if l.strip()), "download failed")
    except Exception as e:
        return False, str(e)

def search_ytm(q, limit=30):
    try:
        yt = YTMusic(str(AUTH)) if AUTH.exists() else YTMusic()
        out = []
        for r in (yt.search(q, filter="songs", limit=limit) or []):
            vid = r.get("videoId") or r.get("id") or ""
            if not vid: continue
            arts = r.get("artists") or []
            art = ", ".join(a.get("name", "") for a in arts if a.get("name")) \
                  if isinstance(arts, list) else ""
            out.append({"id": vid, "title": r.get("title") or "?",
                        "artist": art, "duration": r.get("duration") or "", "source": "online"})
        return out
    except: return []

def get_liked():
    try:
        out = []
        for r in (YTMusic(str(AUTH)).get_liked_songs(limit=100).get("tracks") or []):
            vid = r.get("videoId") or ""
            if not vid: continue
            arts = r.get("artists") or []
            art = ", ".join(a.get("name", "") for a in arts if a.get("name")) \
                  if isinstance(arts, list) else ""
            out.append({"id": vid, "title": r.get("title") or "?",
                        "artist": art, "duration": r.get("duration") or "", "source": "online"})
        return out
    except: return []

def scan_local(folder):
    files = []
    for ext in ("*.mp3", "*.flac", "*.ogg", "*.wav", "*.m4a", "*.opus", "*.aac"):
        files.extend(glob.glob(os.path.join(folder, "**", ext), recursive=True))
    return [{"id": f, "title": os.path.splitext(os.path.basename(f))[0],
             "artist": "local", "duration": "", "source": "local"} for f in sorted(files)]


# ─── custom widgets ───────────────────────────────────────────────────────────

class SearchEdit(urwid.Edit):
    def __init__(self, on_submit):
        super().__init__(caption=("dim", "  search: "))
        self._on_submit = on_submit

    def keypress(self, size, key):
        if key == "enter":
            self._on_submit(self.edit_text.strip())
            return None
        return super().keypress(size, key)


class SelectableRow(urwid.WidgetWrap):
    """A selectable row — swaps markup on focus so >> appears on the focused row.
    wrap='clip' prevents text from wrapping to a second line (fixes ListBoxError)."""
    def __init__(self, markup_normal, markup_focused=None, focus_map="focus"):
        self._markup_normal  = markup_normal
        self._markup_focused = markup_focused if markup_focused is not None else markup_normal
        self._text   = urwid.Text(markup_normal, wrap='clip')   # clip not clip=True
        self._mapped = urwid.AttrMap(self._text, None, focus_map)
        super().__init__(self._mapped)

    def render(self, size, focus=False):
        self._text.set_text(self._markup_focused if focus else self._markup_normal)
        return super().render(size, focus)

    def selectable(self): return True
    def keypress(self, size, key): return key


