# ── mpv ───────────────────────────────────────────────────────────────────────

MPV_SOCK = "/tmp/music-mpv.sock"

class Mpv:
    def __init__(self):
        self._proc = None; self._lock = threading.Lock()
        self.paused = False; self.volume = 80

    def _cmd(self, cmd, want_reply=False):
        try:
            s = socket.socket(socket.AF_UNIX, socket.SOCK_STREAM)
            s.settimeout(1); s.connect(MPV_SOCK)
            s.sendall((json.dumps(cmd) + "\n").encode())
            if want_reply:
                d = json.loads(s.recv(4096).decode())
                s.close(); return d.get("data")
            s.close()
        except: return None

    def play(self, url):
        self.stop(); time.sleep(0.15)
        with self._lock:
            self._proc = subprocess.Popen(
                ["mpv", "--no-video", "--really-quiet",
                 f"--volume={self.volume}",
                 f"--input-ipc-server={MPV_SOCK}", url],
                stdout=subprocess.DEVNULL, stderr=subprocess.DEVNULL)
            self.paused = False

    def stop(self):
        with self._lock:
            if self._proc:
                try: self._proc.terminate(); self._proc.wait(timeout=2)
                except:
                    try: self._proc.kill()
                    except: pass
                self._proc = None; self.paused = False

    def toggle_pause(self):
        self._cmd({"command": ["cycle", "pause"]}); self.paused = not self.paused

    def seek(self, s): self._cmd({"command": ["seek", s, "relative"]})
    def set_vol(self, v):
        self.volume = max(0, min(130, v))
        self._cmd({"command": ["set_property", "volume", self.volume]})
    def pos(self):
        v = self._cmd({"command": ["get_property", "time-pos"]}, want_reply=True)
        return float(v) if v is not None else 0.0
    def dur(self):
        v = self._cmd({"command": ["get_property", "duration"]}, want_reply=True)
        return float(v) if v is not None else 0.0
    def alive(self):
        with self._lock:
            return self._proc is not None and self._proc.poll() is None

MPV = Mpv()

# ── helpers ───────────────────────────────────────────────────────────────────

def fmt(s):
    s = int(max(0, s)); return f"{s//60:02d}:{s%60:02d}"

def pbar(pos, dur, w=36):
    if dur <= 0: return "░" * w
    n = int(min(pos/dur, 1.0) * w)
    return "█" * n + "░" * (w - n)

def stream_url(vid):
    try:
        r = subprocess.run(
            ["yt-dlp", "-x", "--audio-format", "best", "-g", "--no-playlist",
             "--quiet", "--no-warnings",
             f"https://music.youtube.com/watch?v={vid}"],
            capture_output=True, text=True, timeout=20)
        lines = [l.strip() for l in r.stdout.splitlines() if l.strip().startswith("http")]
        return lines[0] if lines else None
    except: return None

def dl_track(vid, title):
    d = str(pathlib.Path.home() / "Music" / "ytmusic")
    os.makedirs(d, exist_ok=True)
    safe = "".join(c for c in title if c.isalnum() or c in " -_")[:80]
    try:
        r = subprocess.run(
            ["yt-dlp", "-x", "--audio-format", "mp3", "--audio-quality", "0",
             "-o", f"{d}/{safe}.%(ext)s", "--no-playlist",
             "--quiet", "--no-warnings",
             f"https://music.youtube.com/watch?v={vid}"],
            capture_output=True, text=True, timeout=120)
        return r.returncode == 0, d
    except Exception as e: return False, str(e)

def search_ytm(query, ft="songs", limit=30):
    try:
        yt = YTMusic(str(AUTH)) if AUTH.exists() else YTMusic()
        results = yt.search(query, filter=ft, limit=limit) or []
        tracks = []
        for r in results:
            vid = r.get("videoId") or r.get("id") or ""
            if not vid: continue
            title = r.get("title") or "Unknown"
            arts  = r.get("artists") or []
            art   = ", ".join(a.get("name","") for a in arts if a.get("name")) if isinstance(arts,list) else ""
            dur   = r.get("duration") or ""
            tracks.append({"id":vid,"title":title,"artist":art,"duration":dur,"source":"online"})
        return tracks
    except Exception as e:
        return []

def get_liked():
    try:
        yt = YTMusic(str(AUTH))
        tracks = []
        for r in (yt.get_liked_songs(limit=100).get("tracks") or []):
            vid = r.get("videoId") or ""
            if not vid: continue
            title = r.get("title") or "Unknown"
            arts  = r.get("artists") or []
            art   = ", ".join(a.get("name","") for a in arts if a.get("name")) if isinstance(arts,list) else ""
            dur   = r.get("duration") or ""
            tracks.append({"id":vid,"title":title,"artist":art,"duration":dur,"source":"online"})
        return tracks
    except: return []

def scan_local(folder):
    exts = ("*.mp3","*.flac","*.ogg","*.wav","*.m4a","*.opus","*.aac")
    files = []
    for ext in exts:
        files.extend(glob.glob(os.path.join(folder, "**", ext), recursive=True))
    tracks = []
    for f in sorted(files):
        name = os.path.splitext(os.path.basename(f))[0]
        tracks.append({"id":f,"title":name,"artist":"local","duration":"","source":"local"})
    return tracks

